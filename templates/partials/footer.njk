    <!-- Footer -->
    <footer
      id="app-footer"
      class="app-footer"
      aria-label="Нижняя строка состояния"
      data-i18n-aria="footer.aria"
    >
      <div class="app-footer__bar">
        <div class="app-footer__zone app-footer__zone--lead">
          <span class="app-footer__kicker" data-i18n="footer.kicker">Thunder Load</span>
          <div
            id="app-version-label"
            class="app-footer__context version-container"
            title="Версия приложения"
            data-i18n-title="topbar.appVersion"
          >
            <span id="footer-app-version">v?</span>
          </div>
        </div>

        <div class="app-footer__zone app-footer__zone--center">
          <div id="footer-status-cluster" class="app-footer__status-cluster">
            <div class="app-footer__zone app-footer__zone--status">
              <span
                id="footer-status-meta"
                class="app-footer__status-meta"
                data-i18n="footer.sectionLabel"
                >Раздел</span
              >
              <strong
                id="footer-active-section"
                class="app-footer__status-value"
                title="Текущий активный раздел"
                aria-live="polite"
                >Загрузчик</strong
              >
            </div>
            <div
              id="footer-tools-status"
              class="app-footer__tools-status downloader-tools-status is-context-hidden"
              aria-hidden="true"
            >
              <div
                class="status-line downloader-tools-status__line"
                id="dl-tools-status"
                role="status"
                aria-live="polite"
              >
                <i
                  class="fa-solid fa-circle-notch fa-spin downloader-tools-status__state-icon"
                  id="dl-tools-icon"
                  aria-hidden="true"
                ></i>
                <span
                  id="dl-tools-text"
                  class="downloader-tools-status__text"
                  data-i18n="downloader.tools.checking"
                >
                  Проверяем инструменты…
                </span>
                <div
                  class="tool-badges downloader-tools-status__badges"
                  id="dl-tools-badges"
                ></div>
              </div>
              <button
                type="button"
                class="downloader-tools-status__reinstall"
                id="dl-tools-reinstall"
                title="Переустановить зависимости (yt-dlp, ffmpeg, Deno)"
                data-bs-toggle="tooltip"
                data-i18n-title="downloader.tools.reinstallTitle"
              >
                <i class="fa-solid fa-arrow-rotate-right"></i>
                <span data-i18n="downloader.tools.reinstall">Переустановить</span>
              </button>
            </div>
          </div>

          <div
            id="footer-tab-nav"
            class="app-footer__tab-nav"
            role="navigation"
            aria-label="Навигация по разделам"
            data-i18n-aria="topbar.nav"
            hidden
          ></div>
        </div>

        <div class="app-footer__zone app-footer__zone--actions">
          <button
            id="open-history"
            class="app-footer__action app-footer__action--history"
            type="button"
            title="История загрузок"
            data-bs-toggle="tooltip"
            data-bs-placement="top"
            data-i18n-title="topbar.history"
            aria-label="Открыть историю загрузок"
            data-hotkey="Ctrl+H"
          >
            <i class="fa-solid fa-clock-rotate-left" aria-hidden="true"></i>
          </button>

          <button
            id="footer-open-settings"
            class="app-footer__action"
            type="button"
            title="Открыть настройки"
            data-bs-toggle="tooltip"
            data-bs-placement="top"
            data-i18n-title="footer.openSettings"
            aria-label="Открыть настройки приложения"
            data-i18n-aria="footer.openSettingsAria"
          >
            <i class="fa-solid fa-sliders" aria-hidden="true"></i>
          </button>

          <button
            id="footer-back-to-top"
            class="app-footer__action app-footer__action--ghost"
            type="button"
            title="Вернуться наверх"
            data-bs-toggle="tooltip"
            data-bs-placement="top"
            data-i18n-title="footer.backToTop"
            aria-label="Прокрутить страницу к началу"
            data-i18n-aria="footer.backToTopAria"
            hidden
          >
            <i class="fa-solid fa-arrow-up" aria-hidden="true"></i>
          </button>
        </div>
      </div>
    </footer>

    <div class="downloader-bg-preload"></div>
