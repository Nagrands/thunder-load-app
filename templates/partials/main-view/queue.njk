  <div id="download-queue-info" class="download-queue-info hidden">
    <div class="queue-header">
      <div class="queue-header-left">
        <span class="queue-title-icon" aria-hidden="true"><i data-lucide="list-video"></i></span>
        <h3 class="queue-title" data-i18n="queue.title">Очередь</h3>
        <div class="queue-pills" aria-label="Сводка очереди">
