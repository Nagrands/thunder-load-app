          <i data-lucide="play"></i>
          <span data-i18n="queue.start">Запустить</span>
        </button>
        <button
          id="queue-pause-button"
          class="queue-action-button queue-action-button--pause"
          aria-label="Пауза очереди"
          title="Пауза очереди"
          data-i18n-title="queue.pause.title"
          data-i18n-aria="queue.pause.title"
        >
          <i data-lucide="pause"></i>
        </button>
        <button
          id="queue-toggle-button"
          class="queue-toggle-button"
          aria-label="Свернуть очередь"
          title="Свернуть очередь"
          data-i18n-title="queue.toggle.collapse.title"
          data-i18n-aria="queue.toggle.collapse.title"
        >
          <i data-lucide="chevron-up"></i>
        </button>
        <span class="queue-actions-divider" aria-hidden="true"></span>
        <button
          id="queue-retry-failed-button"
          class="queue-action-button queue-action-button--ghost hidden"
          aria-label="Повторить все ошибки"
          title="Повторить все ошибки"
          data-i18n-title="queue.retryFailed.title"
          data-i18n-aria="queue.retryFailed.title"
        >
          <i data-lucide="refresh-cw"></i>
        </button>
        <button
          id="queue-retry-transient-button"
          class="queue-action-button queue-action-button--ghost hidden"
          aria-label="Повторить временные ошибки"
          title="Повторить временные ошибки"
          data-i18n-title="queue.retryTransient.title"
          data-i18n-aria="queue.retryTransient.title"
        >
          <i data-lucide="rotate-cw"></i>
        </button>
        <button
          id="queue-clear-failed-button"
          class="queue-action-button queue-action-button--ghost hidden"
          aria-label="Очистить ошибки"
          title="Очистить ошибки"
          data-i18n-title="queue.clearFailed.title"
          data-i18n-aria="queue.clearFailed.title"
        >
          <i data-lucide="badge-x"></i>
        </button>
        <button
          id="queue-clear-done-button"
          class="queue-action-button queue-action-button--ghost hidden"
          aria-label="Очистить готовые"
          title="Очистить готовые"
          data-i18n-title="queue.clearDone.title"
          data-i18n-aria="queue.clearDone.title"
        >
          <i data-lucide="archive-x"></i>
        </button>
        <button
          id="queue-clear-button"
          class="queue-action-button queue-action-button--clear"
          aria-label="Очистить очередь"
          title="Очистить очередь"
          data-i18n-title="queue.clear.title"
          data-i18n-aria="queue.clear.title"
        >
          <i data-lucide="trash-2"></i>
        </button>
      </div>
    </div>

    <div id="queue-list" class="queue-list" aria-live="polite" role="list">
      <div class="queue-empty">
        <span class="queue-empty-icon" aria-hidden="true"><i data-lucide="inbox"></i></span>
