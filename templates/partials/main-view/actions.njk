<!-- Модальное окно выбора качества -->
<div
  id="download-quality-modal"
  class="modal-overlay download-quality-modal"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  aria-labelledby="download-quality-title"
  aria-describedby="download-quality-hint-text"
>
  <div class="modal-content download-quality-content">
    <div class="quality-modal-header">
      <div>
        <p class="quality-modal-subtitle" data-i18n="quality.subtitle">
          Загрузка
        </p>
        <h3 id="download-quality-title" data-i18n="quality.title">
          Выбор качества
        </h3>
      </div>
      <button
        type="button"
        class="quality-modal-close"
        aria-label="Закрыть окно"
        data-i18n-aria="quality.close"
        data-quality-close
      >
        &times;
      </button>
    </div>

    <div class="quality-modal-body">
      <div class="quality-preview">
        <div class="quality-thumb">
          <img id="download-quality-thumb" alt="" loading="lazy" />
          <div class="quality-thumb-overlay" aria-hidden="true">
            <span id="download-quality-cover-title" class="quality-thumb-kicker"></span>
            <strong id="download-quality-cover-genre" class="quality-thumb-genre hidden"></strong>
          </div>
          <div id="download-quality-thumb-fallback" class="quality-thumb-fallback hidden">
            <i class="fa-regular fa-image" aria-hidden="true"></i>
            <span data-i18n="quality.previewUnavailable">Превью недоступно</span>
          </div>
        </div>
        <div class="quality-info">
          <div class="quality-title-row">
            <h4 id="download-quality-name"></h4>
            <button
              type="button"
              id="download-quality-copy-title"
              class="btn-link quality-title-copy"
              data-bs-toggle="tooltip"
              data-bs-placement="top"
              title="Копировать название"
              data-i18n-title="quality.copyTitle"
              aria-label="Копировать название"
              data-i18n-aria="quality.copyTitle"
            >
              <i class="fa-regular fa-copy" aria-hidden="true"></i>
            </button>
          </div>
          <p id="download-quality-uploader"></p>
          <p id="download-quality-duration"></p>
          <p id="download-quality-preview-resolution" data-i18n="quality.previewResolutionUnknown">
            Разрешение превью: —
          </p>
          <div class="quality-link-row">
            <button
              type="button"
              id="download-quality-open-source"
              class="btn-link"
              data-bs-toggle="tooltip"
              data-bs-placement="top"
              title="Открыть источник"
              data-i18n-title="quality.openSource"
              aria-label="Открыть источник"
              data-i18n-aria="quality.openSource"
            >
              <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i>
            </button>
            <button
              type="button"
              id="download-quality-download-preview"
              class="btn-link"
              data-bs-toggle="tooltip"
              data-bs-placement="top"
              title="Скачать превью"
              data-i18n-title="quality.downloadPreview"
              aria-label="Скачать превью"
              data-i18n-aria="quality.downloadPreview"
            >
              <i class="fa-regular fa-image" aria-hidden="true"></i>
            </button>
            <button
              type="button"
              id="download-quality-copy-source"
              class="btn-link"
              data-bs-toggle="tooltip"
              data-bs-placement="top"
              title="Копировать информацию"
              data-i18n-title="quality.copyFileInfo"
              aria-label="Копировать информацию"
              data-i18n-aria="quality.copyFileInfo"
            >
              <i class="fa-regular fa-copy" aria-hidden="true"></i>
            </button>
          </div>
        </div>
      </div>

      <div class="quality-selector">
        <div class="quality-tabs-row">
          <div class="quality-tabs" role="tablist">
            <button
              type="button"
              id="download-quality-tab-video"
              class="quality-tab active"
              data-quality-tab="video"
              role="tab"
              aria-selected="true"
              tabindex="0"
              aria-controls="download-quality-options-panel"
              title="Видео + аудио"
              data-i18n-title="quality.tab.video"
              aria-label="Видео + аудио"
              data-i18n-aria="quality.aria.tab.video"
            >
              <i class="fa-solid fa-film" aria-hidden="true"></i>
              <span data-i18n="quality.tab.video">Видео + аудио</span>
              <span
                class="quality-tab-count"
                id="download-quality-count-video"
                aria-hidden="true"
              >
                0
              </span>
            </button>
            <button
              type="button"
              id="download-quality-tab-video-only"
              class="quality-tab"
              data-quality-tab="video-only"
              role="tab"
              aria-selected="false"
              tabindex="-1"
              aria-controls="download-quality-options-panel"
              title="Только видео"
              data-i18n-title="quality.tab.videoOnly"
              aria-label="Только видео"
              data-i18n-aria="quality.aria.tab.videoOnly"
            >
              <i class="fa-solid fa-video" aria-hidden="true"></i>
              <span data-i18n="quality.tab.videoOnly">Только видео</span>
              <span
                class="quality-tab-count"
                id="download-quality-count-video-only"
                aria-hidden="true"
              >
                0
              </span>
            </button>
            <button
              type="button"
              id="download-quality-tab-audio"
              class="quality-tab"
              data-quality-tab="audio"
              role="tab"
              aria-selected="false"
              tabindex="-1"
              aria-controls="download-quality-options-panel"
              aria-label="Только аудио"
              data-i18n-aria="quality.aria.tab.audio"
            >
              <i class="fa-solid fa-music" aria-hidden="true"></i>
              <span data-i18n="quality.tab.audio">Только аудио</span>
              <span
                class="quality-tab-count"
                id="download-quality-count-audio"
                aria-hidden="true"
              >
                0
              </span>
            </button>
          </div>
        </div>
        <div id="download-quality-loading" class="quality-loading">
          <div class="quality-loading-main">
            <i class="fa-solid fa-spinner fa-spin"></i>
            <span data-i18n="quality.loading">Загрузка доступных форматов...</span>
          </div>
          <small
            id="download-quality-loading-detail"
            class="quality-loading-detail"
            data-i18n="quality.loading.detail"
          >
            Обычно это занимает до 15 секунд.
          </small>
          <div class="quality-loading-skeleton" aria-hidden="true">
            <span class="quality-skeleton-line"></span>
            <span class="quality-skeleton-line"></span>
            <span class="quality-skeleton-line"></span>
          </div>
        </div>
        <div
          id="download-quality-options-placeholder"
          class="quality-options-placeholder hidden"
          aria-hidden="true"
        >
          <div class="quality-placeholder-card">
            <span class="quality-placeholder-title"></span>
            <span class="quality-placeholder-line"></span>
            <span class="quality-placeholder-badges"></span>
          </div>
          <div class="quality-placeholder-card">
            <span class="quality-placeholder-title"></span>
            <span class="quality-placeholder-line"></span>
            <span class="quality-placeholder-badges"></span>
          </div>
          <div class="quality-placeholder-card">
            <span class="quality-placeholder-title"></span>
            <span class="quality-placeholder-line"></span>
            <span class="quality-placeholder-badges"></span>
          </div>
        </div>
        <div
          id="download-quality-error"
          class="quality-error hidden"
          role="alert"
          aria-live="assertive"
        >
          <div class="quality-error-text">
            <span data-i18n="quality.error"
              >Не удалось получить информацию о видео.</span
            >
          </div>
          <button
            type="button"
            id="download-quality-retry"
            class="quality-retry-btn"
          >
            <i class="fa-solid fa-rotate-right"></i>
            <span data-i18n="quality.retry">Повторить</span>
          </button>
        </div>
        <div id="download-quality-empty" class="quality-empty hidden">
          <span data-i18n="quality.empty"
            >Нет вариантов для выбранного режима.</span
          >
          <small class="quality-empty-help" data-i18n="quality.empty.help">
            Попробуйте переключить вкладку или нажать «Повторить».
          </small>
        </div>
        <div
          id="download-quality-options-panel"
          class="quality-options-panel"
          role="tabpanel"
          aria-labelledby="download-quality-tab-video"
        >
          <div
            id="download-quality-options"
            class="quality-options"
            role="radiogroup"
            aria-live="polite"
            aria-busy="false"
            aria-label="Доступные форматы"
            data-i18n-aria="quality.aria.optionsGroup"
            aria-describedby="download-quality-hint-text download-quality-selection-title"
          ></div>
        </div>
        <div
          id="download-quality-selection-summary"
          class="quality-selection-summary"
          aria-live="polite"
          aria-label="Сводка выбранного качества"
          data-i18n-aria="quality.aria.selectionSummary"
        >
          <div class="quality-selection-text">
            <span class="quality-selection-label" data-i18n="quality.selected">
              Выбрано
            </span>
            <strong id="download-quality-selection-title" data-i18n="quality.notSelected">
              Вариант не выбран
            </strong>
            <small id="download-quality-selection-meta" data-i18n="quality.selectHint">
              Выберите качество в списке выше.
            </small>
            <small
              id="download-quality-selection-output"
              data-i18n="quality.resultPlaceholder"
            >
              Итог загрузки появится после выбора варианта.
            </small>
          </div>
          <button type="button" id="download-quality-best-current" class="quality-best-current-btn">
            <i class="fa-solid fa-wand-magic-sparkles"></i>
            <span data-i18n="quality.bestCurrent">Лучшее в этой вкладке</span>
          </button>
        </div>
      </div>
    </div>

    <div class="quality-modal-footer">
      <div class="quality-hint">
        <div class="quality-hint-texts">
          <span id="download-quality-hint-text" data-i18n="quality.hint"
            >Выберите вариант выше, затем скачайте его сразу или добавьте в очередь.</span
          >
          <div class="quality-hotkeys" aria-label="Горячие клавиши выбора качества">
            <div class="quality-hotkeys-main">
              <span class="hotkey-chip"
                ><kbd>↑/↓</kbd> <span data-i18n="quality.hotkey.select">выбор</span></span
              >
              <span class="hotkey-chip"
                ><kbd>Enter</kbd> <span id="download-quality-hotkey-confirm-label" data-i18n="quality.hotkey.confirm">скачать</span></span
              >
              <span class="hotkey-chip"
                ><kbd>A</kbd> <span data-i18n="quality.hotkey.enqueue">в очередь</span></span
              >
              <span class="hotkey-chip"
                ><kbd>Esc</kbd> <span data-i18n="quality.hotkey.close">закрыть</span></span
              >
            </div>
          </div>
        </div>
      </div>
      <div class="quality-actions">
        <button
          type="button"
          id="download-quality-cancel"
          class="btn-ghost"
          data-i18n="quality.cancel"
        >
          Отмена
        </button>
        <div class="quality-split-actions">
          <button
            type="button"
            id="download-quality-action-enqueue"
            class="btn-ghost quality-split-secondary"
            data-bs-toggle="tooltip"
            data-bs-placement="top"
            title="Добавить в очередь"
            data-i18n-title="quality.enqueueHint"
            aria-label="Добавить в очередь"
            data-i18n-aria="quality.enqueueHint"
            disabled
          >
            <i class="fa-solid fa-list-check" aria-hidden="true"></i>
            <span class="quality-split-secondary-label" data-i18n="quality.split.action.enqueue"
              >Добавить в очередь</span
            >
          </button>
          <button
            type="button"
            id="download-quality-primary"
            class="btn-primary quality-split-primary"
            disabled
            data-i18n="quality.split.primary"
          >
            <i class="fa-solid fa-download" aria-hidden="true"></i>
            <span>Скачать</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
