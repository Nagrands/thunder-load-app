<!-- Группа кнопок -->
<nav
  class="button-group"
  aria-label="Основные действия"
  data-i18n-aria="actions.primary"
>
  <!-- Кнопка открытия последнего видео -->
  <button
    id="open-last-video"
    class="small-button btn btn-sm btn-secondary"
    aria-label="Открыть последнее скачанное видео"
    data-i18n-aria="actions.openLast"
    disabled
    data-bs-toggle="tooltip"
    data-bs-placement="top"
    title="Последнее видео"
    data-i18n-title="actions.lastVideo"
  >
    <i class="fa fa-play" aria-hidden="true"></i>
  </button>

  <!-- Группа кнопок скачивания и выбора качества -->
  <div class="download-quality-group">
    <!-- Кнопка скачивания -->
    <button id="download-button" class="large-button btn btn-lg btn-primary" disabled aria-disabled="true">
      <i class="fas fa-download"></i>
      <span class="button-text" data-i18n="actions.download">Скачать</span>
    </button>

    <!-- Кнопка отмены скачивания -->
    <button
      id="download-cancel"
      class="small-button btn btn-sm btn-danger"
    aria-label="Отменить скачивание"
    data-i18n-aria="actions.cancelDownload"
    disabled
    data-bs-toggle="tooltip"
    data-bs-placement="top"
    title="Отменить скачивание"
    data-i18n-title="actions.cancelDownload"
  >
      <i class="fa-solid fa-xmark"></i>
    </button>
  </div>

  <!-- Кнопка открытия папки с видео -->
  <button
    id="open-folder"
    class="small-button btn btn-sm btn-secondary"
    aria-label="Открыть папку с видео"
    data-i18n-aria="actions.openFolder"
    data-bs-toggle="tooltip"
    data-bs-placement="top"
    title="Папка с видео"
    data-i18n-title="actions.videoFolder"
  >
    <i class="fa-regular fa-folder-open"></i>
  </button>
</nav>

<!-- Модальное окно выбора качества -->
<div
  id="download-quality-modal"
  class="modal-overlay download-quality-modal"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  aria-labelledby="download-quality-title"
>
  <div class="modal-content download-quality-content">
    <div class="quality-modal-header">
      <div>
        <p class="quality-modal-subtitle" data-i18n="quality.subtitle">
          Загрузка
        </p>
        <h3 id="download-quality-title" data-i18n="quality.title">
          Выбор качества
        </h3>
      </div>
      <button
        type="button"
        class="quality-modal-close"
        aria-label="Закрыть окно"
        data-i18n-aria="quality.close"
        data-quality-close
      >
        &times;
      </button>
    </div>

    <div class="quality-modal-body">
      <div class="quality-preview">
        <div class="quality-thumb">
          <img id="download-quality-thumb" alt="" loading="lazy" />
        </div>
        <div class="quality-info">
          <h4 id="download-quality-name"></h4>
          <p id="download-quality-uploader"></p>
          <p id="download-quality-duration"></p>
          <button
            type="button"
            id="download-quality-open-source"
            class="btn-link"
          >
            <i class="fa-solid fa-arrow-up-right-from-square"></i>
            <span data-i18n="quality.openSource">Открыть источник</span>
          </button>
        </div>
      </div>

      <div class="quality-selector">
        <div class="quality-tabs-row">
          <div class="quality-tabs" role="tablist">
            <button
              type="button"
              class="quality-tab active"
              data-quality-tab="video"
              data-i18n="quality.tab.video"
            >
              Видео + аудио
            </button>
            <button
              type="button"
              class="quality-tab"
              data-quality-tab="video-only"
              data-i18n="quality.tab.videoOnly"
            >
              Только видео
            </button>
            <button type="button" class="quality-tab" data-quality-tab="audio">
              <span data-i18n="quality.tab.audio">Только аудио</span>
            </button>
          </div>
          <button
            type="button"
            id="download-quality-best"
            class="quality-best-link"
          >
            <i class="fa-solid fa-bullseye"></i>
            <span data-i18n="quality.best">Максимальное качество</span>
          </button>
        </div>
        <div id="download-quality-loading" class="quality-loading">
          <i class="fa-solid fa-spinner fa-spin"></i>
          <span data-i18n="quality.loading"
            >Загрузка доступных форматов...</span
          >
        </div>
        <div
          id="download-quality-error"
          class="quality-error hidden"
          role="alert"
          aria-live="assertive"
        >
          <div class="quality-error-text">
            <span data-i18n="quality.error"
              >Не удалось получить информацию о видео.</span
            >
          </div>
          <button
            type="button"
            id="download-quality-retry"
            class="quality-retry-btn"
          >
            <i class="fa-solid fa-rotate-right"></i>
            <span data-i18n="quality.retry">Повторить</span>
          </button>
        </div>
        <div id="download-quality-empty" class="quality-empty hidden">
          <span data-i18n="quality.empty"
            >Нет вариантов для выбранного режима.</span
          >
        </div>
        <div
          id="download-quality-options"
          class="quality-options"
          role="radiogroup"
          aria-live="polite"
        ></div>
      </div>
    </div>

    <div class="quality-modal-footer">
      <div class="quality-hint">
        <i class="fa-regular fa-circle-question"></i>
        <span data-i18n="quality.hint"
          >Двойной клик по варианту сразу начнёт загрузку.</span
        >
      </div>
      <div class="quality-actions">
        <button
          type="button"
          id="download-quality-cancel"
          class="btn-ghost"
          data-i18n="quality.cancel"
        >
          Отмена
        </button>
        <button
          type="button"
          id="download-quality-confirm"
          class="btn-primary"
          disabled
          data-i18n="quality.confirm"
        >
          Скачать выбранное
        </button>
      </div>
    </div>
  </div>
</div>
