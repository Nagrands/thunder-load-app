<div class="top-bar">
  <div class="top-bar__left" data-topbar-priority="p1">
    <div class="brand-chip">
      {# <img
        src="../assets/icons/thunder-logo.png"
        alt="Логотип Thunder Load"
        loading="lazy"
      /> #}
      <div class="brand-meta">
        <span class="brand-title">Thunder</span>
        <div
          class="app-version-label version-container"
          id="app-version-label"
          data-bs-toggle="tooltip"
          data-bs-placement="bottom"
          title="Версия приложения"
          data-i18n-title="topbar.appVersion"
        >
          <i class="fas fa-bolt fa-beat-fade"></i>
          <span class="version">v<span id="app-version">?</span></span>
        </div>
      </div>
    </div>
  </div>

  <div class="top-bar__center" data-topbar-priority="p1">
    <div
      class="center-menu"
      role="tablist"
      aria-label="Навигация по разделам"
      data-i18n-aria="topbar.nav"
    >
      <div class="group-menu"></div>
    </div>
  </div>

  <div class="top-bar__right">
    <div class="top-bar__right-group">
      <div class="quick-actions" aria-label="Быстрые действия" data-i18n-aria="topbar.quickActions">
        <button
          class="menu-item"
          id="open-history"
          data-topbar-priority="p3"
          data-bs-toggle="tooltip"
          data-bs-placement="bottom"
          title="История загрузок"
          data-i18n-title="topbar.history"
          data-hotkey="Ctrl+H"
        >
          <span class="menu-main">
            <i class="fa-solid fa-clock-rotate-left"></i>
            <span class="menu-text" data-i18n="topbar.action.history">История</span>
          </span>
        </button>

        <button
          class="menu-item"
          id="shortcuts-button"
          data-topbar-priority="p3"
          data-bs-toggle="tooltip"
          data-bs-placement="bottom"
          title="Горячие клавиши"
          data-i18n-title="topbar.shortcuts"
          data-hotkey="Ctrl+P"
        >
          <span class="menu-main">
            <i class="fas fa-keyboard"></i>
            <span class="menu-text" data-i18n="topbar.action.shortcuts">Клавиши</span>
          </span>
        </button>

        <button
          class="menu-item"
          id="settings-button"
          data-topbar-priority="p2"
          data-bs-toggle="tooltip"
          data-bs-placement="bottom"
          title="Настройки"
          data-i18n-title="topbar.settings"
          data-hotkey="Ctrl+,"
        >
          <span class="menu-main">
            <i class="fa-solid fa-gear"></i>
            <span class="menu-text" data-i18n="topbar.action.settings">Настройки</span>
          </span>
        </button>

        <button
          class="menu-item"
          id="theme-toggle"
          data-topbar-priority="p2"
          data-bs-toggle="tooltip"
          data-bs-placement="bottom"
          title="Сменить тему"
          data-i18n-title="topbar.theme"
        >
          <span class="menu-main">
            <i class="fa-solid fa-palette"></i>
            <span class="menu-text" data-i18n="topbar.action.theme">Тема</span>
          </span>
        </button>

        <button
          class="menu-item"
          id="open-github"
          data-topbar-priority="p3"
          data-bs-toggle="tooltip"
          data-bs-placement="bottom"
          title="Открыть репозиторий на GitHub"
          data-i18n-title="topbar.github"
        >
          <span class="menu-main">
            <i class="fa-brands fa-github"></i>
            <span class="menu-text" data-i18n="topbar.action.github">GitHub</span>
          </span>
        </button>

        <button
          id="reload-app"
          data-topbar-priority="p3"
          data-bs-toggle="tooltip"
          data-bs-placement="bottom"
          title="Обновить окно"
          data-i18n-title="topbar.reload"
          data-hotkey="Ctrl+R"
        >
          <span class="menu-main">
            <i class="fa-solid fa-arrow-rotate-right"></i>
            <span class="menu-text" data-i18n="topbar.action.reload">Обновить</span>
          </span>
        </button>
      </div>

      <div
        class="network-status"
        id="network-status"
        data-topbar-priority="p3"
        role="status"
        aria-live="polite"
        data-i18n-aria="topbar.network.aria"
        data-bs-toggle="tooltip"
        data-bs-placement="bottom"
      >
        <span class="network-status__dot" aria-hidden="true"></span>
        <span class="network-status__text" id="network-status-text">—</span>
      </div>

      <span class="top-bar__divider" aria-hidden="true"></span>

      <div class="window-controls" data-topbar-priority="p1">
        <button
          class="btn-minimize"
          title="Свернуть"
          data-i18n-title="topbar.minimize"
          onclick="window.electron.minimize()"
        >
          <i class="fas fa-window-minimize"></i>
        </button>
        <button
          class="btn-close"
          title="Закрыть"
          data-i18n-title="topbar.close"
          onclick="window.electron.close()"
        >
          <i class="fas fa-times"></i>
        </button>
      </div>

      <div class="topbar-more-wrap">
        <button
          class="topbar-more"
          id="topbar-more-toggle"
          type="button"
          data-topbar-priority="p1"
          aria-expanded="false"
          aria-controls="topbar-overflow-menu"
          aria-haspopup="true"
          title="Ещё действия"
          data-i18n-title="topbar.more"
          data-i18n-aria="topbar.more"
        >
          <i class="fa-solid fa-ellipsis"></i>
          <span class="topbar-more__text" data-i18n="topbar.more">Ещё</span>
        </button>

        <div
          class="topbar-overflow"
          id="topbar-overflow-menu"
          role="menu"
          hidden
          aria-label="Быстрые действия"
          data-i18n-aria="topbar.overflow.aria"
        >
          <button class="topbar-overflow__item" type="button" role="menuitem" data-proxy-target="#open-history">
            <i class="fa-solid fa-clock-rotate-left"></i>
            <span data-i18n="topbar.action.history">История</span>
          </button>
          <button class="topbar-overflow__item" type="button" role="menuitem" data-proxy-target="#shortcuts-button">
            <i class="fas fa-keyboard"></i>
            <span data-i18n="topbar.action.shortcuts">Клавиши</span>
          </button>
          <button class="topbar-overflow__item" type="button" role="menuitem" data-proxy-target="#settings-button">
            <i class="fa-solid fa-gear"></i>
            <span data-i18n="topbar.action.settings">Настройки</span>
          </button>
          <button class="topbar-overflow__item" type="button" role="menuitem" data-proxy-target="#theme-toggle">
            <i class="fa-solid fa-palette"></i>
            <span data-i18n="topbar.action.theme">Тема</span>
          </button>
          <button class="topbar-overflow__item" type="button" role="menuitem" data-proxy-target="#open-github">
            <i class="fa-brands fa-github"></i>
            <span data-i18n="topbar.action.github">GitHub</span>
          </button>
          <button class="topbar-overflow__item" type="button" role="menuitem" data-proxy-target="#reload-app">
            <i class="fa-solid fa-arrow-rotate-right"></i>
            <span data-i18n="topbar.action.reload">Обновить</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <div
    id="top-download-progress"
    class="top-download-progress"
    aria-hidden="true"
  >
    <div id="top-download-progress-fill" class="top-download-progress-fill"></div>
  </div>
</div>
