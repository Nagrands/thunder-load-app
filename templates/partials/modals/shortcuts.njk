      <!-- Shortcuts Modal -->
      <div
        id="shortcuts-modal"
        class="shortcuts-modal"
        role="dialog"
        aria-modal="true"
        aria-labelledby="shortcuts-title"
      >
        <div class="shortcuts-modal-content">
          <button class="close" aria-label="Закрыть" data-i18n-aria="modal.close">
            &times;
          </button>
          <h2 id="shortcuts-title">
            <i class="far fa-keyboard"></i>
            <span data-i18n="modal.shortcuts">Горячие клавиши</span>
          </h2>
          <details class="spoiler" open>
            <summary>
              <i class="fas fa-chevron-right"></i>
              <span data-i18n="shortcuts.main">Основные</span>
            </summary>
            <ul class="main-hotkeys">
              <hr />
              <li>
                <strong>Ctrl + P</strong>
                <p>
                  <i class="far fa-keyboard"></i>
                  <span data-i18n="shortcuts.openShortcuts"
                    >Горячие клавиши</span
                  >
                </p>
              </li>
              <li>
                <strong>Ctrl + ,</strong>
                <p>
                  <i class="fa-solid fa-gear"></i>
                  <span data-i18n="shortcuts.openSettings">Настройки</span>
                </p>
              </li>
              <li>
                <strong>Ctrl + T</strong>
                <p>
                  <i class="fa-solid fa-toggle-on"></i>
                  <span data-i18n="shortcuts.toggleTheme"
                    >Переключить тему</span
                  >
                </p>
              </li>
              <hr />
              <li>
                <strong>Ctrl + 1</strong>
                <p>
                  <i class="fa-solid fa-download"></i>
                  <span data-i18n="shortcuts.tab.downloader"
                    >Вкладка «Downloader»</span
                  >
                </p>
              </li>
              <li>
                <strong>Ctrl + 2</strong>
                <p>
                  <i class="fa-solid fa-screwdriver-wrench"></i>
                  <span data-i18n="shortcuts.tab.wg">Вкладка «Tools»</span>
                </p>
              </li>
              <li>
                <strong>Ctrl + 3</strong>
                <p>
                  <i class="fa-solid fa-box-archive"></i>
                  <span data-i18n="shortcuts.tab.backup">
                    Инструмент Backup в Tools
                  </span>
                </p>
              </li>
            <hr />
            <li>
              <strong>Ctrl + H</strong>
              <p>
                <i class="fa-solid fa-clock-rotate-left"></i>
                <span data-i18n="shortcuts.history">История загрузок</span>
              </p>
              </li>
              <li>
                <strong>Ctrl + K</strong>
                <p>
                  <i class="fa-regular fa-folder-open"></i>
                  <span data-i18n="shortcuts.downloadsFolder"
                    >Папка с загрузками</span
                  >
                </p>
              </li>
              <li
                data-bs-toggle="tooltip"
                data-bs-placement="top"
                title="При наличии ссылки в поле ввода URL"
                data-i18n-title="shortcuts.downloadHint"
              >
                <strong>Ctrl + D</strong>
                <p>
                  <i class="fas fa-download"></i>
                  <span data-i18n="shortcuts.startDownload"
                    >Начать скачивание</span
                  >
                </p>
              </li>
              <li>
                <strong>Ctrl + L</strong>
                <p>
                  <i class="fa-solid fa-circle-play"></i>
                  <span data-i18n="shortcuts.lastVideo"
                    >Последнее загруженное видео</span
                  >
                </p>
              </li>
              <li>
                <strong>Ctrl + M</strong>
                <p>
                  <i class="fas fa-trash-alt"></i>
                  <span data-i18n="shortcuts.clearHistory"
                    >Очистить историю загрузок</span
                  >
                </p>
              </li>
            </ul>
          </details>

          <details class="spoiler">
            <summary>
              <i class="fas fa-chevron-right"></i>
              <span data-i18n="shortcuts.special">Специальные клавиши</span>
            </summary>
            <ul class="additional-hotkeys">
              <span class="short-info" data-i18n="shortcuts.openSites"
                >Открытие сайтов</span
              >
              <hr />
              <li>
                <strong>Ctrl + Shift + 1</strong>
                <p><i class="fab fa-youtube"></i> YouTube</p>
              </li>
              <li>
                <strong>Ctrl + Shift + 2</strong>
                <p><i class="fab fa-twitch"></i> Twitch</p>
              </li>
              <li>
                <strong>Ctrl + Shift + 3</strong>
                <p>
                  <i class="fab fa-vk"></i>
                  <span data-i18n="shortcuts.site.vk">VK Видео</span>
                </p>
              </li>
              <li>
                <strong>Ctrl + Shift + 4</strong>
                <p><i class="fas fa-video"></i> Coub</p>
              </li>
            </ul>
          </details>
        </div>
      </div>
