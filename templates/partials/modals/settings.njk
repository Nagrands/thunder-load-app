                      <button class="dropdown-toggle" id="theme-dropdown-btn">
                        <span id="theme-selected-label" data-i18n="settings.appearance.theme.dark">
                          Dark
                        </span>
                        <i class="fa-solid fa-chevron-down"></i>
                      </button>
                      <ul class="dropdown-menu" id="theme-dropdown-menu">
                        <li data-value="dark" data-i18n="settings.appearance.theme.dark">
                          Dark
                        </li>
                        <li data-value="midnight" data-i18n="settings.appearance.theme.midnight">
                          Midnight
                        </li>
                        <li data-value="sunset" data-i18n="settings.appearance.theme.sunset">
                          Sunset
                        </li>
                        <li data-value="violet" data-i18n="settings.appearance.theme.violet">
                          Violet
                        </li>
                        <li data-value="light" data-i18n="settings.appearance.theme.light">
                          Light
                        </li>
                      </ul>
                    </div>
                    <button
                      id="reset-theme"
                      class="dropdown-reset"
                      data-bs-toggle="tooltip"
                      data-bs-placement="top"
                      title="Сбросить тему по умолчанию"
                      data-i18n-title="settings.appearance.theme.reset"
                    >
                      <i class="fa-solid fa-rotate-left"></i>
                    </button>
                  </li>

                  <li class="custom-theme-select">
                    <label for="font-size-dropdown-btn">
                      <i class="fa-solid fa-text-height"></i>
                      <span data-i18n="settings.appearance.fontSize">Размер текста</span>
                    </label>

                    <div class="dropdown">
                      <button
                        class="dropdown-toggle"
                        id="font-size-dropdown-btn"
                      >
                        <span id="font-size-selected-label">16 px</span>
                        <i class="fa-solid fa-chevron-down"></i>
                      </button>
                      <ul class="dropdown-menu" id="font-size-dropdown-menu">
                        <li data-value="14">14 px</li>
                        <li data-value="16">16 px</li>
                        <li data-value="18">18 px</li>
                        <li data-value="20">20 px</li>
                      </ul>
                    </div>

                    <button
                      id="reset-font-size"
                      class="dropdown-reset"
                      data-bs-toggle="tooltip"
                      data-bs-placement="top"
                      title="Сбросить размер шрифта по умолчанию"
                      data-i18n-title="settings.appearance.fontSize.reset"
                    >
                      <i class="fa-solid fa-rotate-left"></i>
                    </button>
                  </li>

                  <li>
                    <input type="checkbox" id="settings-low-effects-toggle" />
                    <label for="settings-low-effects-toggle" data-bs-toggle="tooltip"
                      data-bs-placement="top"
                      title="Отключает анимации и эффекты размытия"
                      data-i18n-title="settings.appearance.lowEffects.hint">
                      <i class="fa-solid fa-leaf"></i>
                      <span data-i18n-html="settings.appearance.lowEffects">
                        Режим <strong>экономии эффектов</strong>
                      </span>
                    </label>
                  </li>
                      </ul>
                    </div>
                  </section>
                </div>
              </div>

              <!-- Other Settings Tab -->
              <div id="other-settings" class="tab-pane">
                <div class="settings-pane-header">
                  <h2 data-i18n="settings.other.title">Другие настройки</h2>
                  <p data-i18n="settings.other.hint">
                    Дополнительные параметры для детальной настройки поведения приложения.
                  </p>
                </div>
                <div class="settings-grid">
                  <section class="settings-card">
                    <h3 class="settings-card__title">Горячие клавиши</h3>
                    <div class="settings-card__body">
                      <ul class="module settings-control-list">
                        <li class="settings-control">
                          <input
                            type="checkbox"
                            id="settings-disable-global-shortcuts-toggle"
                          />
                          <label for="settings-disable-global-shortcuts-toggle">
                            <i class="fa-solid fa-keyboard"></i>
                            <span data-i18n-html="settings.other.disableHotkeys">
                              Отключить <strong>специальные</strong> (горячие) клавиши
                            </span>
                          </label>
                        </li>
                      </ul>
                    </div>
                  </section>

                  <section class="settings-card">
                    <h3 class="settings-card__title" data-i18n="settings.developer.title">
                      Для разработчика
                    </h3>
                    <p class="settings-card__desc" data-i18n="settings.developer.hint">
                      Введите секретное слово, чтобы активировать скрытые функции во вкладке Tools.
                    </p>
                    <div class="settings-card__body">
                      <div class="settings-developer-gate">
                        <label
                          for="settings-developer-secret-input"
                          class="settings-developer-gate__label"
                          data-i18n="settings.developer.secret.label"
                        >
                          Секретное слово
                        </label>
                        <div class="settings-developer-gate__controls">
                          <input
                            type="password"
                            id="settings-developer-secret-input"
                            class="settings-developer-gate__input"
                            autocomplete="off"
                            placeholder="Введите слово"
                            data-i18n-placeholder="settings.developer.secret.placeholder"
                          />
                          <button
                            type="button"
                            id="settings-developer-activate-button"
                            class="settings-developer-gate__button"
                            data-i18n="settings.developer.activate"
                          >
                            Активировать
                          </button>
                        </div>
                        <small
                          id="settings-developer-status"
                          class="settings-developer-gate__status muted"
                          data-i18n="settings.developer.status.disabled"
                        >
                          Функции разработчика выключены
                        </small>
                      </div>
                    </div>
                  </section>

                  <section class="settings-card settings-card--stacked">
                    <h3 class="settings-card__title" data-i18n="settings.other.appConfig">Настройки приложения</h3>
                    <div class="settings-card__body">
                      <div class="module export-import-section">
                        <button id="export-config-button">
                          <i class="fa-solid fa-download"></i>
                          <span data-i18n="settings.other.export">Сохранить</span>
                        </button>
                        <button id="import-config-button">
                          <i class="fa-solid fa-upload"></i>
                          <span data-i18n="settings.other.import">Загрузить</span>
                        </button>
                        <button id="open-config-folder-button">
                          <i class="fa-solid fa-folder-open"></i>
                          <span data-i18n="settings.other.openFolder">Папка настроек</span>
                        </button>
                        <input
                          type="file"
                          id="import-config-input"
                          accept=".json"
                          style="display: none"
                        />
                      </div>
                    </div>
                  </section>

                  <section class="settings-card settings-card--stacked">
                    <h3 class="settings-card__title" data-i18n="settings.other.resetTitle">Сброс настроек</h3>
                    <div class="settings-card__body">
                      <div class="module reset-settings-section">
                        <button id="reset-config-button">
                          <i class="fa-solid fa-rotate-left"></i>
                          <span data-i18n="settings.other.reset">Настройки по умолчанию</span>
                        </button>
                        <button id="first-run-reset-button">
                          <i class="fa-solid fa-wand-magic-sparkles"></i>
                          <span data-i18n="settings.other.firstRun">Первичная настройка</span>
                        </button>
                      </div>
                    </div>
                  </section>
                </div>
              </div>
            </div>

            <div
              id="settings-tools-modal"
              class="settings-tools-modal"
              role="dialog"
              aria-modal="true"
              aria-labelledby="settings-tools-modal-title"
              style="display: none"
            >
              <div class="settings-tools-modal__content" role="document">
                <button
                  type="button"
                  id="settings-tools-close"
                  class="settings-tools-modal__close"
                  aria-label="Закрыть инструменты"
                  data-i18n-aria="modal.close"
                >
                  &times;
                </button>
                <header class="settings-tools-modal__header">
                  <h2 id="settings-tools-modal-title" data-i18n="settings.tools.modal.title">
                    Инструменты
                  </h2>
                  <p data-i18n="settings.tools.modal.subtitle">
                    Проверка статуса, переустановка и смена папки зависимостей.
                  </p>
                </header>
                <div class="settings-tools-shell">
                  <section id="tools-info" class="settings-section">
                    <p class="muted" data-i18n="settings.tools.loading">
                      Загружаем сведения о зависимостях…
                    </p>
                  </section>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
