# Normalize text files and keep a consistent LF checkout across platforms.
* text=auto eol=lf

# Source files
*.js text eol=lf
*.cjs text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.scss text eol=lf
*.css text eol=lf
*.html text eol=lf
*.njk text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Shell scripts
*.sh text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.svg binary
*.woff2 binary

# Generated artifacts
src/css/* linguist-generated=true
src/index.html linguist-generated=true
